    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.19",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "mysql2": "^3.12.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
